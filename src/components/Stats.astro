---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---
<section class="py-12 bg-primary text-white">
  <div class="max-w-6xl mx-auto px-4 grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
    {stats.map(stat => (
      <div>
        <div class="text-3xl md:text-4xl font-heading font-bold">{stat.value}</div>
        <div class="mt-1 text-sm opacity-80">{stat.label}</div>
      </div>
    ))}
  </div>
</section>
