---
interface Question {
  q: string;
  a: string;
}

interface Props {
  headline?: string;
  questions: Question[];
}

const { headline = 'Често задавани въпроси', questions } = Astro.props;

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": questions.map(q => ({
    "@type": "Question",
    "name": q.q,
    "acceptedAnswer": { "@type": "Answer", "text": q.a }
  }))
};
---
<section id="faq" class="py-16 md:py-24 px-4 bg-surface">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-heading font-bold text-center mb-12">{headline}</h2>
    <div class="space-y-4">
      {questions.map((q, i) => (
        <details class="group bg-bg rounded-[var(--radius)] border border-border overflow-hidden">
          <summary class="flex items-center justify-between p-5 cursor-pointer font-medium hover:text-primary transition-colors">
            {q.q}
            <span class="text-muted group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <div class="px-5 pb-5 text-muted text-sm leading-relaxed">{q.a}</div>
        </details>
      ))}
    </div>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
</section>
