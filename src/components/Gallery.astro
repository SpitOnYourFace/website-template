---
interface Props {
  headline?: string;
  images: { src: string; alt: string }[];
  columns?: 2 | 3 | 4;
}

const { headline = 'Галерия', images, columns = 3 } = Astro.props;
const gridCols = { 2: 'md:grid-cols-2', 3: 'md:grid-cols-3', 4: 'md:grid-cols-2 lg:grid-cols-4' };
---
<section id="gallery" class="py-16 md:py-24 px-4">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-heading font-bold text-center mb-12">{headline}</h2>
    <div class={`grid gap-4 ${gridCols[columns]}`}>
      {images.map(img => (
        <div class="overflow-hidden rounded-[var(--radius)] shadow-[var(--shadow)] group">
          <img src={img.src} alt={img.alt} class="w-full h-64 object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
        </div>
      ))}
    </div>
  </div>
</section>
