<button id="back-to-top" aria-label="Нагоре"
  class="fixed bottom-6 left-6 z-50 bg-primary text-white w-12 h-12 rounded-full flex items-center justify-center shadow-lg opacity-0 pointer-events-none transition-opacity hover:scale-110">
  ↑
</button>
<script>
  const btn = document.getElementById('back-to-top');
  window.addEventListener('scroll', () => {
    if (!btn) return;
    if (window.scrollY > 400) {
      btn.classList.remove('opacity-0', 'pointer-events-none');
    } else {
      btn.classList.add('opacity-0', 'pointer-events-none');
    }
  });
  btn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
</script>
