---
interface Props {
  headline?: string;
  text: string;
  image?: string;
  imagePosition?: 'left' | 'right';
}

const { headline = 'За нас', text, image, imagePosition = 'right' } = Astro.props;
---
<section id="about" class="py-16 md:py-24 px-4">
  <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
    <div class={imagePosition === 'right' ? '' : 'md:order-2'}>
      <h2 class="text-3xl md:text-4xl font-heading font-bold mb-6">{headline}</h2>
      <p class="text-muted leading-relaxed whitespace-pre-line">{text}</p>
    </div>
    {image && (
      <div class={imagePosition === 'right' ? '' : 'md:order-1'}>
        <img src={image} alt={headline} class="rounded-[var(--radius)] shadow-[var(--shadow-lg)] w-full" loading="lazy" />
      </div>
    )}
  </div>
</section>
